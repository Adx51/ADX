# ─────────────────────────────────────────────────────────────
# ADX — Environment variables (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────

# Database (PostgreSQL + pgvector)
DATABASE_URL="postgresql://adx:adx@localhost:5432/adx?schema=public"

# API
API_PORT=4000
API_URL="http://localhost:4000"
CORS_ORIGIN="http://localhost:3000"

# Auth
JWT_SECRET="change-me-in-production-please"
JWT_EXPIRES_IN="7d"

# AI — any OpenAI-compatible provider (optional; degrades gracefully without a key)
OPENAI_API_KEY=""
# Leave OPENAI_BASE_URL empty for OpenAI. For Google Gemini (free tier), set:
#   OPENAI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
#   OPENAI_MODEL="gemini-2.0-flash"  OPENAI_VISION_MODEL="gemini-2.0-flash"
#   (get a free key at https://aistudio.google.com/apikey)
OPENAI_BASE_URL=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_VISION_MODEL="gpt-4o"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Object storage (Supabase or AWS S3)
S3_ENDPOINT=""
S3_REGION="eu-west-3"
S3_BUCKET="adx-uploads"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Web
NEXT_PUBLIC_API_URL="http://localhost:4000"
