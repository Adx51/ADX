# ─────────────────────────────────────────────────────────────
# ADX — Environment variables (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────

# Database (PostgreSQL + pgvector)
DATABASE_URL="postgresql://adx:adx@localhost:5432/adx?schema=public"

# API
API_PORT=4000
API_URL="http://localhost:4000"
CORS_ORIGIN="http://localhost:3000"

# Auth
JWT_SECRET="change-me-in-production-please"
JWT_EXPIRES_IN="7d"

# AI — OpenAI (optional; the app degrades gracefully without a key)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_VISION_MODEL="gpt-4o"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Object storage (Supabase or AWS S3)
S3_ENDPOINT=""
S3_REGION="eu-west-3"
S3_BUCKET="adx-uploads"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Web
NEXT_PUBLIC_API_URL="http://localhost:4000"
