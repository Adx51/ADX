PORT=3001
NODE_ENV=production

# Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-generate-a-long-random-string

# Chemin vers la base SQLite (relatif au répertoire de lancement)
DB_PATH=./data/adx.db

# Dossier de stockage des photos
PHOTOS_DIR=./data/photos

# Optionnel: restreindre les origines CORS (ex: http://adx.local)
# ALLOWED_ORIGIN=*
